// EPOXIDOVO Prisma schema
// Database: Postgres (Neon free tier on production)
// Models: Lead (dopyt z formulárov), User + Account + Session + VerificationToken (NextAuth)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Dopyt z formulára na webe (kontaktný form, cenová ponuka, sample picker)
model Lead {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Identifikácia zákazníka
  name        String
  email       String
  phone       String?

  // Detaily dopytu
  spaceType   String?  // dom | garaz | hala-firma
  service     String?  // jednofarebne | chipsove | mramorove | metalicke | nezvolene
  area        Int?     // m² približne
  message     String?  @db.Text

  // Tracking
  source      String   @default("contact_form") // contact_form | callback | sample_picker | service_page
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  referrer    String?
  userAgent   String?

  // Stav
  status      LeadStatus @default(NEW)
  notes       String?    @db.Text  // interné poznámky pre admina

  @@index([createdAt])
  @@index([status])
  @@index([email])
}

enum LeadStatus {
  NEW
  CONTACTED
  QUOTED
  WON
  LOST
}

/// NextAuth users (admin, kto môže vidieť leady)
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(VIEWER)
  accounts      Account[]
  sessions      Session[]
}

enum UserRole {
  ADMIN
  VIEWER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
