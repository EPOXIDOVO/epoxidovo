// EPOXIDOVO Prisma schema
// Database: Postgres (Neon free tier on production)
// Models: Lead (dopyt z formulárov), User + Account + Session + VerificationToken (NextAuth)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Dopyt z formulára na webe (kontaktný form, cenová ponuka, sample picker)
/// Plus leady z Meta Lead Ads a Google Lead Form (po napojení webhookov).
model Lead {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Identifikácia zákazníka
  name        String
  email       String
  phone       String?

  // Detaily dopytu
  spaceType   String?  // dom | garaz | hala-firma
  service     String?  // jednofarebne | chipsove | mramorove | metalicke | nezvolene
  area        Int?     // m² približne
  message     String?  @db.Text

  // Tracking
  source      String   @default("web") // web | meta | google | callback | sample_picker
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  referrer    String?
  userAgent   String?

  // Stav + workflow
  status              LeadStatus @default(NEW)
  notes               String?    @db.Text // interné poznámky agenta
  failedCallCount     Int        @default(0)
  lastStatusChangeAt  DateTime?  // kedy bol naposledy zmenený status (pre cron drip)
  followupSentAt      DateTime?  // kedy sa poslal auto-followup (aby sa neposlal 2×)
  reviewRequestSentAt DateTime?  // kedy sa poslal review request po realizácii

  @@index([createdAt])
  @@index([status])
  @@index([email])
  @@index([source])
}

enum LeadStatus {
  NEW              // čerstvý lead, nezvolaný
  CALLED_NO_ANSWER // volal som, nedovolal som sa
  CONTACTED        // volal som, má záujem, ďalšie kroky
  QUOTED           // ponuka odoslaná
  WON              // podpísaná zmluva
  REALIZED         // hotová realizácia (podlaha položená)
  NOT_INTERESTED   // zákazník nemá záujem
  LOST             // stratený / unreachable po viacerých pokusoch
}

/// Používateľ s prístupom do /admin alebo /leady.
/// Rola riadi kam môže ísť:
///   - ADMIN  → /admin (full) + /leady
///   - AGENT  → iba /leady (call agent)
///   - VIEWER → iba čítanie (rezervované pre budúce použitie)
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(AGENT) // default pri vytvorení adminom je AGENT
  active        Boolean   @default(true)  // dá sa deaktivovať bez zmazania
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
}

enum UserRole {
  ADMIN
  AGENT
  VIEWER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
